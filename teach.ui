      <widget class="QTabWidget" name="tabWidgetSig_3">
       <property name="geometry">
        <rect>
         <x>10</x>
         <y>10</y>
         <width>401</width>
         <height>461</height>
        </rect>
       </property>
       <property name="minimumSize">
