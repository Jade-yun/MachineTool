/**********************************************************/
QTableWidget{
	background-color:#ADE2F4;
	alternate-background-color:#F8FAD2;
	border:1px solid black;
	gridline-color:#0F0963;
}

 QScrollBar:vertical
{ /*滑块设置*/
	width:40px;
	background: rgb(238, 238, 236);
	margin:0px,0px,0px,0px;
	padding-top:50px;
	padding-bottom:50px;
}
QScrollBar::handle:vertical
{/*滑块样式设置，背景色，四角倒角4px*/
	background: rgb(60, 189, 245);
	border-radius:8px;
}
/*设置上键头*/
QScrollBar::sub-line:vertical
{
	height:60px;width:40px;
	border-image:url(:/images/up.png)；
}
/*设置下键头*/
QScrollBar::add-line:vertical
{
	height:60px;width:40px;
	border-image:url(:/images/down.png)；
}
/*按压时的颜色*/
QScrollBar::handle:vertical:hover
{
	background:rgb(46, 165, 250);
	border-radius:4px;
}

</string>
