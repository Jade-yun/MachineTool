  <property name="styleSheet">
   <string notr="true">QLabel { 
	font-family: 'SimSun';
	font-size: 22px; 
}

QWidget{ 
	font-family: 'SimSun';
	font-size: 22px; 
}

/************************************************/
QPushButton
{
    background-color:#F0F4FD;
    border-style:solid; /*边框风格*/
    border-width:1px;/*边框宽度*/
    border-color:#7A77AC; /*边框颜色*/
    border-radius:10px; /*边框倒角*/
/*
	font-family: DejaVuSansMono;
*/
	font-weight:normal;
	font-family: 'SimSun';
	background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,stop: 0 #FFFAFA, stop: 0.4 #EEE9E9,stop: 0.5 #EEE9E9, stop: 1.0 #CDC9C9);
}
QPushButton:pressed
{
    border-style:outset; /*边框风格*/
    background-color:qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop:0 #00befa, stop: 1 #0160ea);/*背景色*/
    border-width:1px;/*边框宽度*/
    border-color:#0055ff; /*边框颜色*/
    border-radius:10px; /*边框倒角*/
}

/******************************************************/
QGroupBox {
	border: 1px solid black;
	border-radius:5px;
	margin-top:10px; 
}
QGroupBox::title { 
	subcontrol-origin: margin;
	left: 10px;
	bottom: 5px;
}
/*****************************************************/
QCheckBox { 
/*
	font-size: 20px;
	font-weight:normal;
	font-family: 'SimSun';
*/
}
QCheckBox::indicator{
	width: 30px;
	height: 30px;
	border: 1px solid black; 
	background-color: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,stop: 0 #FFFAFA, stop: 0.4 #EEE9E9,stop: 0.5 #EEE9E9, stop: 1.0 #CDC9C9);
}

QCheckBox::indicator:checked {
background-color: qlineargradient(x1 : 0, y1 : 0, x2 : 1, y2 : 0,stop : 0 #F8F8FF, stop: 1 #1E90FF); 
        image: url(:/images/check_mark.png);
        border-image: none;
    }

/*****************************************************************/
QComboBox::!editable {
	border: 2px solid #808A87; /* 边框宽度和颜色 */
}
QComboBox::drop-down {
    subcontrol-origin: padding-right;
    subcontrol-position: top right;
    width: 20px; /* 下拉箭头宽度 */
    border-left-width: 2px; /* 文本和箭头之间的分隔线宽度 */
    border-left-color: gray; /* 文本和箭头之间的分隔线颜色 */
    border-left-style: solid; /* 文本和箭头之间的分隔线样式 */
}
QComboBox::down-arrow {
    image: url(:/images/arrow_down_normal.png); /* 自定义下拉箭头图片 */
}

QComboBox QAbstractItemView::item:hover{ 
  background-color:#409CE1;
  color:rgb(252, 233, 79);
}
QComboBox QAbstractItemView::item:selected{
  background-color:#909CE1;
  color:rgb(252, 200, 140);
}
/**************************************************/
QTabWidget::tab-bar{
        alignment:left;
}
QTabBar::tab{
	background:rgb(160, 160, 160);
	width:100px;
	height:40px;
}
/*
QTabBar::tab:hover{
	background:rgb(255, 255, 255, 100);
}
*/
QTabBar::tab:selected {
      border-color: #9B9B9B;
      border-bottom-color: #C2C7CB; /* same as pane color */
  }
QTabBar::tab:!selected {
      margin-top: 2px; /* make non-selected tabs look smaller */
  }
  QTabWidget::pane { /* The tab widget frame */
      border-top: 2px solid #C2C7CB;
  }

  QTabWidget::tab-bar {
      left: 5px; /* move to the right by 5px */
  }

  /* Style the tab using the tab sub-control. Note that
      it reads QTabBar _not_ QTabWidget */
  QTabBar::tab {

	background-color:qlineargradient(x1 : 0, y1 : 0, x2 : 0, y2 : 1, stop : 0 #00befa, stop: 1 #0160ea);
      border: 2px solid #C4C4C3;
      border-bottom-color: #C2C7CB; /* same as the pane color */
      border-top-left-radius: 4px;
      border-top-right-radius: 4px;
      min-width: 8ex;
      padding: 2px;
  }

  QTabBar::tab:selected, QTabBar::tab:hover {
      background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                  stop: 0 #fafafa, stop: 0.4 #f4f4f4,
                                  stop: 0.5 #e7e7e7, stop: 1.0 #fafafa);
  }

  QTabBar::tab:selected {
      border-color: #9B9B9B;
      border-bottom-color: #C2C7CB; /* same as pane color */
  }

  QTabBar::tab:!selected {
      margin-top: 2px; /* make non-selected tabs look smaller */
  }

QTabWidget::pane {
    border: 1px solid #000000; /* 设置边框样式和颜色 */
}



